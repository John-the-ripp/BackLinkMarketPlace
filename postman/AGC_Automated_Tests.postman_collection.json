{
  "info": {
    "name": "WINAITYBACKLINKS - AGC Automated Tests",
    "_postman_id": "agc-automated-tests-001",
    "description": "Collection automatisée pour tester tous les endpoints AGC du marketplace. Exécuter via Collection Runner dans l'ordre.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "agcToken", "value": "" },
    { "key": "agcId", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "clientId2", "value": "" },
    { "key": "subUserToken", "value": "" },
    { "key": "subUserId", "value": "" },
    { "key": "subUserEmail", "value": "" },
    { "key": "annonceurToken", "value": "" },
    { "key": "annonceurId", "value": "" },
    { "key": "acheteurToken", "value": "" },
    { "key": "acheteurId", "value": "" },
    { "key": "backlinkId", "value": "" }
  ],
  "item": [
    {
      "name": "00 - Setup",
      "item": [
        {
          "name": "00.1 Register Annonceur (seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Annonceur registered', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has access_token and user', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('access_token');",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user.role).to.eql('annonceur');",
                  "    pm.collectionVariables.set('annonceurToken', json.access_token);",
                  "    pm.collectionVariables.set('annonceurId', json.user.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vendeur Test\",\n  \"email\": \"vendeur_{{$timestamp}}@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"annonceur\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "00.2 Create Backlink (for later purchase)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - Backlink created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Backlink has correct fields', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json.status).to.eql('available');",
                  "    pm.collectionVariables.set('backlinkId', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{annonceurToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example-{{$timestamp}}.com/backlink\",\n  \"anchorText\": \"best tech blog\",\n  \"targetUrl\": \"https://target-site.com/page1\",\n  \"price\": 25.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/backlinks", "host": ["{{baseUrl}}"], "path": ["backlinks"] }
          }
        }
      ]
    },
    {
      "name": "01 - AGC Registration",
      "item": [
        {
          "name": "01.1 Register AGC",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 - AGC registered', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('User role is agc', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.user.role).to.eql('agc');",
                  "});",
                  "",
                  "pm.test('Has access_token', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('access_token');",
                  "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('agcToken', json.access_token);",
                  "    pm.collectionVariables.set('agcId', json.user.id);",
                  "});",
                  "",
                  "pm.test('Wallet is 0 for AGC', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(Number(json.user.wallet)).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Agence Test Auto\",\n  \"email\": \"agc_{{$timestamp}}@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"agc\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "01.2 AGC cannot register as agc_sub",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 - agc_sub not allowed at registration', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fake Sub\",\n  \"email\": \"fakesub_{{$timestamp}}@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"agc_sub\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        }
      ]
    },
