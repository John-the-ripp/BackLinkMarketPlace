                "exec": [
                  "// Register an acheteur if not yet done",
                  "if (!pm.collectionVariables.get('acheteurToken')) {",
                  "    pm.sendRequest({",
                  "        url: pm.collectionVariables.get('baseUrl') + '/auth/register',",
                  "        method: 'POST',",
                  "        header: { 'Content-Type': 'application/json' },",
                  "        body: { mode: 'raw', raw: JSON.stringify({",
                  "            name: 'Acheteur Test',",
                  "            email: 'acheteur_' + Date.now() + '@test.com',",
                  "            password: 'password123',",
                  "            role: 'acheteur'",
                  "        })}",
                  "    }, function (err, res) {",
                  "        var json = res.json();",
                  "        pm.collectionVariables.set('acheteurToken', json.access_token);",
                  "        pm.collectionVariables.set('acheteurId', json.user.id);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
