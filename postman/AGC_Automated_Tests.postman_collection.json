    {
      "name": "07 - Purchase Flow (AGC)",
      "item": [
        {
          "name": "07.1 AGC buys backlink for Client A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 - Purchase successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Backlink is now sold', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('sold');",
                  "    pm.expect(json.buyerId).to.be.a('number');",
                  "    pm.expect(json.clientId).to.eql(Number(pm.collectionVariables.get('clientId')));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
